zstyle ':vcs_info:git:*' formats ' (%b)'

# Enable prompt substitution
setopt PROMPT_SUBST

# colors
FG_BLUE="%F{4}"     # structure
FG_CYAN="%F{14}"     # identity
FG_GREEN="%F{2}"    # success
FG_YELLOW="%F{11}"  # warning/root
FG_RED="%F{196}"     # error
FG_DIM="%F{245}"     # subtle
RESET="%f"

# Exit status indicator (critical signal)
exit_status() {
  if [[ $? -ne 0 ]]; then
    echo "${FG_RED}✖${RESET} "
  else
    echo "${FG_GREEN}✔${RESET} "
  fi
}

# Root indicator
root_indicator() {
  if [[ $EUID -eq 0 ]]; then
    echo "${FG_YELLOW}#${RESET}"
  else
    echo "${FG_DIM}$ ${RESET}"
  fi
}

# Git branch (minimal, no noise)
git_branch() {
  local branch
  branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
  if [[ -n "$branch" ]]; then
    echo " ${FG_DIM}(${branch})${RESET}"
  fi
}

# Enable vi keybindings
bindkey -v

# Track mode
function zle-keymap-select {
  case $KEYMAP in
    vicmd)
      MODE="%F{4}N%f" ;;     # NORMAL  (blue)
    viins|main)
      MODE="%F{2}I%f" ;;     # INSERT  (green)
    visual)
      MODE="%F{5}V%f" ;;     # VISUAL  (magenta)
    replace)
      MODE="%F{3}R%f" ;;     # REPLACE (yellow)
    *)
      MODE="%F{243}?%f" ;;
  esac
  zle reset-prompt
}

               # check for python venv. Display python emoji when in a venv dir
precmd() {
  if [[ -n "$VIRTUAL_ENV" ]]; then
    local name=$(basename "$VIRTUAL_ENV")
    VENV_PROMPT="%F{green}🐍($name)%f "
  else
    VENV_PROMPT=""
  fi
}

zle -N zle-keymap-select

                                                   # Initialize mode on startup
function zle-line-init {
  zle-keymap-select
}
zle -N zle-line-init

PROMPT=' $(exit_status)'\
'${FG_CYAN}%n@%m${RESET} '\
'${FG_BLUE}%~${RESET}'\
'$(git_branch) '\
'${MODE} ${VENV_PROMP} $(root_indicator) '
