# ======================== Python Hax ==========================================
autoload -Uz add-zsh-hook
_auto_venv() {                       # auto-activate python venv on cd into dir
                          # if alread inside a venv, check if should deactivate
    if [[ -n "$VIRTUAL_ENV" ]]; then
        if [[ ! -f ".venv/bin/activate" ]]; then
            deactivate 2>/dev/null
        fi
    fi

    if [[ -z "$VIRTUAL_ENV" && ".venv/bin/activate" ]]; then
        source .venv/bin/activate
    fi
}
add-zsh-hook chpwd _auto_venv
